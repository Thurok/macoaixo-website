---
import stickerPhoto from '../assets/IMG_20260127_080501_076.jpg';
---

<section class="hero" id="inici">
	<div class="container hero-grid">
		<div class="hero-copy">
			<p class="eyebrow">Adhesius amb accent català</p>
			<h1>Porta Catalunya allà on vagis.</h1>
			<p class="intro">
				MacoAixò crea adhesius per a catalans viatgers que volen compartir cultura, humor i identitat
				arreu del món amb un gest petit però inconfusible.
			</p>
			<div class="hero-actions">
				<a class="cta" href="https://ko-fi.com/macoaixo" target="_blank" rel="noreferrer">Comprar ara</a>
			</div>
		</div>

		<div class="hero-visual" aria-hidden="true">
			<div class="photo-wrap">
				<img src={stickerPhoto.src} alt="" loading="eager" />
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		padding: clamp(3rem, 7vw, 6.4rem) 0 3.2rem;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: clamp(1.2rem, 3vw, 2.7rem);
		align-items: center;
	}

	.hero-copy h1 {
		font-size: clamp(2.1rem, 6vw, 4.2rem);
		line-height: 1.02;
		letter-spacing: -0.04em;
		margin: 0;
	}

	.eyebrow {
		display: inline-flex;
		padding: 0.42rem 0.72rem;
		margin-bottom: 1rem;
		border-radius: 999px;
		background: color-mix(in oklab, var(--brand-yellow) 72%, white 28%);
		font-weight: 600;
	}

	.intro {
		max-width: 52ch;
		font-size: clamp(1rem, 2vw, 1.24rem);
		color: var(--muted);
		margin: 1.2rem 0 0;
	}

	.hero-actions {
		margin-top: 1.5rem;
	}

	.cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.88rem 1.35rem;
		border-radius: 999px;
		background: var(--brand-red);
		color: #fff;
		text-decoration: none;
		font-weight: 700;
	}

	.hero-visual {
		position: relative;
	}

	.photo-wrap {
		position: relative;
		border-radius: 28px;
		overflow: hidden;
		box-shadow: var(--shadow-soft);
		background: #fff;
	}

	.photo-wrap::after {
		content: '';
		position: absolute;
		inset: auto 0 0;
		height: 40%;
		background: linear-gradient(180deg, transparent, rgba(18, 18, 18, 0.2));
	}

	.photo-wrap img {
		display: block;
		width: 100%;
		height: min(62vh, 540px);
		object-fit: cover;
	}

	@media (max-width: 980px) {
		.hero-grid {
			grid-template-columns: 1fr;
		}

		.photo-wrap img {
			height: 420px;
		}
	}

	@media (max-width: 720px) {
		.hero {
			padding-top: 2.4rem;
		}

		.photo-wrap {
			border-radius: 20px;
		}

		.photo-wrap img {
			height: 320px;
		}
	}
</style>