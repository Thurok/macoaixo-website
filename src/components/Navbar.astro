---
import IconInstagram from './icons/IconInstagram.astro';
import IconTikTok from './icons/IconTikTok.astro';
import IconMail from './icons/IconMail.astro';
import { CONTACT_EMAIL, KO_FI_LINK } from '../config';
---

<header class="site-header">
	<div class="container toolbar">
		<a class="brand" href="#inici" aria-label="MacoAixò inici">
			Maco, això.
		</a>

		<nav class="actions" aria-label="Xarxes i compra">
			<a
				class="icon-button"
				href="https://www.instagram.com/macoaixo.cat/"
				target="_blank"
				rel="noreferrer"
				aria-label="Instagram de MacoAixò"
			>
				<IconInstagram />
			</a>

			<a
				class="icon-button"
				href="https://www.tiktok.com/@macoaixo.cat"
				target="_blank"
				rel="noreferrer"
				aria-label="TikTok de MacoAixò"
			>
				<IconTikTok />
			</a>

			<a
				class="icon-button"
				href={`mailto:${CONTACT_EMAIL}`}
				aria-label="Correu de MacoAixò"
			>
				<IconMail />
			</a>

			<a class="buy-button" href={KO_FI_LINK} target="_blank" rel="noreferrer">
			 Botiga
			</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(8px);
		background: color-mix(in oklab, white 80%, var(--brand-yellow) 20%);
		border-bottom: 1px solid color-mix(in oklab, var(--ink) 15%, white 85%);
	}

	.toolbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 0;
		gap: 1rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		height: 42px;
		font-size: clamp(1.2rem, 1.8vw, 1.45rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		text-decoration: none;
		line-height: 1;
	}

	.actions {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
	}

	.icon-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: 999px;
		border: 1px solid color-mix(in oklab, var(--ink) 15%, white 85%);
		background: #fff;
		transition: transform 200ms ease, border-color 200ms ease;
	}

	.icon-button :global(svg) {
		width: 21px;
		height: 21px;
		fill: var(--ink);
	}

	.icon-button:hover {
		transform: translateY(-1px);
		border-color: var(--brand-red);
	}

	.buy-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1.15rem;
		border-radius: 999px;
		background: var(--brand-red);
		color: white;
		text-decoration: none;
		font-weight: 700;
		letter-spacing: 0.01em;
		transition: transform 200ms ease, box-shadow 200ms ease;
	}

	.buy-button:hover {
		transform: translateY(-1px);
		box-shadow: 0 10px 20px rgba(218, 18, 26, 0.25);
	}

	@media (max-width: 720px) {
		.brand {
			height: 38px;
			font-size: 1.1rem;
		}

		.buy-button {
			padding: 0.58rem 0.98rem;
		}
	}
</style>