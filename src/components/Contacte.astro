---
import IconInstagram from './icons/IconInstagram.astro';
import IconTikTok from './icons/IconTikTok.astro';
import IconMail from './icons/IconMail.astro';
import { CONTACT_EMAIL } from '../config';
---

<section class="section contacte" id="contacte">
	<div class="container box">
		<h2>Segueix el moviment</h2>
		<p>Més catalanades cada setmana:</p>

		<div class="socials">
			<a
				class="social-link"
				href="https://www.instagram.com/macoaixo.cat/"
				target="_blank"
				rel="noreferrer"
				aria-label="Instagram de MacoAixò"
			>
				<IconInstagram />
				Instagram
			</a>

			<a
				class="social-link"
				href="https://www.tiktok.com/@macoaixo.cat"
				target="_blank"
				rel="noreferrer"
				aria-label="TikTok de MacoAixò"
			>
				<IconTikTok />
				TikTok
			</a>

			<a
				class="social-link"
				href={`mailto:${CONTACT_EMAIL}`}
				aria-label="Correu de MacoAixò"
			>
				<IconMail />
				Correu
			</a>
		</div>
	</div>
</section>

<style>
	.section {
		padding: clamp(2.4rem, 6vw, 4.8rem) 0;
	}

	.box {
		padding: clamp(1.3rem, 4vw, 2.2rem);
		border-radius: 24px;
		background: linear-gradient(150deg, #fff 0%, #fff7da 85%);
		border: 1px solid color-mix(in oklab, var(--ink) 10%, white 90%);
		box-shadow: var(--shadow-soft);
	}

	h2 {
		font-size: clamp(1.7rem, 4vw, 2.5rem);
		letter-spacing: -0.03em;
		margin: 0;
	}

	p {
		margin: 0.7rem 0 1.1rem;
		color: var(--muted);
	}

	.socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
	}

	.social-link {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		text-decoration: none;
		padding: 0.66rem 0.98rem;
		border-radius: 999px;
		background: #fff;
		border: 1px solid color-mix(in oklab, var(--ink) 16%, white 84%);
		font-weight: 600;
	}

	.social-link :global(svg) {
		width: 18px;
		height: 18px;
		fill: var(--ink);
	}

	.social-link:hover {
		border-color: var(--brand-red);
	}
</style>